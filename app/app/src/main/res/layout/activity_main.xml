<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF121212">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TouchMirror"
            android:textColor="#FFFFFFFF"
            android:textSize="32sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginTop="16dp" />

        <TextView
            android:id="@+id/tvVersion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="v1.0.0"
            android:textColor="#AA888888"
            android:textSize="13sp"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <!-- Status Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#FF1E1E1E"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <View
                        android:id="@+id/statusDot"
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:background="@drawable/status_dot"
                        android:backgroundTint="#FFEF5350" />

                    <TextView
                        android:id="@+id/tvStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Disconnected"
                        android:textColor="#FFFFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginStart="10dp" />

                    <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

                    <TextView
                        android:id="@+id/tvMode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CONTROLLER"
                        android:textColor="#FF1565C0"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:background="@drawable/chip_bg"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvServerUrl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Server: not configured"
                    android:textColor="#AA888888"
                    android:textSize="13sp"
                    android:layout_marginTop="8dp" />

                <TextView
                    android:id="@+id/tvSessionId"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Session: —"
                    android:textColor="#AA888888"
                    android:textSize="13sp"
                    android:layout_marginTop="4dp" />

                <TextView
                    android:id="@+id/tvPeers"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Connected targets: 0"
                    android:textColor="#AA888888"
                    android:textSize="13sp"
                    android:layout_marginTop="4dp" />

                <TextView
                    android:id="@+id/tvLatency"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Latency: —"
                    android:textColor="#AA888888"
                    android:textSize="13sp"
                    android:layout_marginTop="4dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Mirroring State Card (Controller only) -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardMirrorState"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#FF1E1E1E"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="16dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvMirrorState"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Mirroring: ON"
                    android:textColor="#FF4CAF50"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchMirror"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Accessibility Warning (Controller) -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardAccessibility"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#FF2D2000"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="16dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="⚠️ Accessibility Service Required"
                    android:textColor="#FFFFA726"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Enable TouchMirror in Accessibility Settings to capture touch events in Controller mode."
                    android:textColor="#CCFFA726"
                    android:textSize="13sp"
                    android:layout_marginTop="6dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnOpenAccessibility"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Open Accessibility Settings"
                    android:layout_marginTop="10dp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Overlay Warning (Controller) -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardOverlay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#FF2D2000"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="16dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="⚠️ Overlay Permission Required"
                    android:textColor="#FFFFA726"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Allow TouchMirror to display over other apps to show the floating control button."
                    android:textColor="#CCFFA726"
                    android:textSize="13sp"
                    android:layout_marginTop="6dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnGrantOverlay"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Grant Overlay Permission"
                    android:layout_marginTop="10dp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Action Buttons -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConnect"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Connect"
            android:textSize="16sp"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSettings"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Settings"
                android:layout_marginEnd="8dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnShowLog"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Log"
                android:layout_marginStart="8dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
        </LinearLayout>

        <!-- Log Output -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#FF0D0D0D"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            android:layout_marginTop="16dp"
            android:visibility="gone">

            <ScrollView
                android:id="@+id/scrollLog"
                android:layout_width="match_parent"
                android:layout_height="200dp">

                <TextView
                    android:id="@+id/tvLog"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#FF88FF88"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:padding="12dp" />
            </ScrollView>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
