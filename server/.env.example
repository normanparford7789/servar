# TouchMirror Server Configuration
# Copy this to .env and fill in your values

# Server port (Railway sets this automatically)
PORT=3000

# Session secret - ALL devices must use this same secret to connect
# Change this to a strong random string before deploying!
SESSION_SECRET=change_this_to_a_strong_random_secret_123

# Optional: allowed origins for CORS (leave * for all)
CORS_ORIGIN=*
